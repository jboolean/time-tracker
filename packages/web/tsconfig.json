{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "composite": true,
    "outDir": "./dist",
    "paths": {
      "@time-tracker/shared": ["../shared/src/index.ts"],
      "@time-tracker/server/app": ["../server/src/app.ts"]
    }
  },
  "references": [
    { "path": "../shared" },
    { "path": "../server" }
  ],
  "include": ["src"]
}
